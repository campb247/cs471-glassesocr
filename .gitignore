# Chars74K dataset, re-downloadable via `model/download_dataset.py`.
# 294MB; do not commit.
model/data/

# All generated training artifacts (plots, checkpoints, intermediate
# .mlpackage). The iOS app uses glassesocr/CharacterCNN.mlpackage for its
# build, which is committed separately. Everything in model/output/ is
# regeneratable by running train.py + the analysis scripts.
model/output/

# Documents (project description, slideshows, written report). Keep
# only source code and essential build artifacts in the repo.
*.pdf
*.pptx
*.docx

